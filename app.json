{
  "expo": {
    "name": "Nice Place",
    "slug": "nice-place",
    "version": "1.0.0-beta",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "niceplace",
    "ios": {
      "bundleIdentifier": "com.niceplace.app",
      "supportsTablet": true,
      "buildNumber": "1"
    },
    "android": {
      "package": "com.niceplace.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#060A10",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "niceplace",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsVersion": "11.20.1"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nice Place uses your location to show nearby hidden places on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nice Place needs access to your photos so you can add a cover image for places you share."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#060A10"
        }
      ],
      "expo-image"
    ]
  }
}
