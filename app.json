{
  "expo": {
    "name": "Nice Place",
    "slug": "nice-place",
    "version": "1.0.0-beta",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "niceplace",
    "ios": {
      "bundleIdentifier": "com.niceplace.app",
      "supportsTablet": true,
      "buildNumber": "1",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.omeryigitckr.niceplace",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#060A10",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "niceplace",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      "expo-apple-authentication",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsVersion": "11.20.1"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nice Place uses your location to show nearby hidden places on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nice Place needs access to your photos so you can add a cover image for places you share."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#060A10",
          "android": {
            "image": "./assets/android-icon-foreground.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#060A10"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#44A878"
        }
      ],
      "expo-image",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "2d7fc9aa-d493-41cc-83fd-bb47593c2439"
      }
    }
  }
}
